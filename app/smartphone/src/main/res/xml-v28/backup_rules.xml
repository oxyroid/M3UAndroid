<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Keep small user settings in cloud backup. Large app files move device-to-device only. -->
    <include domain="file" path="datastore/settings.preferences_pb" />
    <include domain="database" path="." requireFlags="deviceToDeviceTransfer" />
    <include domain="file" path="." requireFlags="deviceToDeviceTransfer" />
    <include domain="sharedpref" path="." />

    <!-- Secrets and device authorization must be recreated after restore. -->
    <exclude domain="sharedpref" path="extension-settings.xml" />
    <exclude domain="sharedpref" path="extension-setting-secrets.xml" />
    <exclude domain="sharedpref" path="extension-trust.xml" />
    <exclude domain="sharedpref" path="subscription_provider.xml" />
</full-backup-content>
