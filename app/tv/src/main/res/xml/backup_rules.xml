    <include domain="sharedpref" path="." />

    <exclude domain="sharedpref" path="extension-settings.xml" />
    <exclude domain="sharedpref" path="extension-setting-secrets.xml" />
    <exclude domain="sharedpref" path="extension-trust.xml" />
    <exclude domain="sharedpref" path="subscription_provider.xml" />
</full-backup-content>
